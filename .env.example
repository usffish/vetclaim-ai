# Copy this file to .env and fill in your keys
# .env is gitignored — never commit real keys

GOOGLE_API_KEY=your_gemini_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# VA Benefits Reference Data API (sandbox)
VA_API_KEY=your_va_sandbox_key_here

# VA Forms API (sandbox) — get key at: https://developer.va.gov/explore/api/va-forms/sandbox-access
VA_FORMS_API_KEY=your_va_forms_key_here
