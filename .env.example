# Copy this file to .env and fill in your keys
# .env is gitignored — never commit real keys

# Backend API Keys
GOOGLE_API_KEY=your_gemini_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# VA Benefits Reference Data API (sandbox)
VA_API_KEY=your_va_sandbox_key_here

# VA Forms API (sandbox) — get key at: https://developer.va.gov/explore/api/va-forms/sandbox-access
VA_FORMS_API_KEY=your_va_forms_key_here

# Frontend Variables
VITE_API_BASE_URL=http://localhost:5001

# VA Calling Agent (Vapi) — get keys at: https://vapi.ai
VAPI_API_KEY=your_vapi_key_here
VAPI_PHONE_NUMBER_ID=your_vapi_phone_number_id_here

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173

# Mock VA Portal URL
VA_PORTAL_URL=http://localhost:5050
