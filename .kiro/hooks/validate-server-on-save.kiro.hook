{
  "enabled": true,
  "name": "Validate Server on Save",
  "description": "When server.py is saved, checks that all Flask endpoints are intact and the CORS config is still present",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "mock_va_portal/server.py"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "mock_va_portal/server.py was just saved. Check that:\n1. All three required endpoints are still present: POST /submit-appeal, GET /submissions, GET /submissions/<id>/pdf\n2. CORS is still enabled (flask_cors import and CORS(app) call)\n3. The server still runs on port 5050\n4. The submissions/ upload directory is still being created with os.makedirs\nReport any missing pieces. If everything looks good, say so briefly."
  }
}