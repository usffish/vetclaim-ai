{
  "enabled": true,
  "name": "Validate HTML on Save",
  "description": "When a mock VA portal HTML file is saved, checks for missing disclaimer text, broken internal links, and missing lang/title attributes",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "mock_va_portal/*.html"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "A mock VA portal HTML file was just saved. Quickly check it for these three things and flag any issues:\n1. Does the footer contain the required disclaimer: \"Demo mock portal — VetClaim AI HackUSF 2026. Not affiliated with the U.S. Department of Veterans Affairs.\"\n2. Does the <html> tag have lang=\"en\" and does the page have a <title> tag?\n3. Are there any href links pointing to other .html files in the portal that don't exist (e.g. linking to a file that hasn't been created yet)?\nReport any issues found. If everything looks good, say so briefly."
  }
}